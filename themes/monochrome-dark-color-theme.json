{
  "name": "Monochrome Dark (ArcFlow)",
  "type": "dark",
  "colors": {
    "editor.background": "#131313",
    "editor.foreground": "#ffffff",
    "activityBar.background": "#0d0d0d",
    "activityBar.foreground": "#ffffff",
    "sideBar.background": "#0d0d0d",
    "sideBar.foreground": "#cccccc",
    "editorLineNumber.foreground": "#444444",
    "editorLineNumber.activeForeground": "#ffffff",
    "editorCursor.foreground": "#ffffff",
    "editor.selectionBackground": "#ffffff20",
    "statusBar.background": "#0d0d0d",
    "statusBar.foreground": "#888888",
    "tab.activeBackground": "#131313",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#0d0d0d",
    "tab.inactiveForeground": "#666666",
    "breadcrumb.foreground": "#888888",
    "list.activeSelectionBackground": "#1a1a1a",
    "list.hoverBackground": "#1a1a1a"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ffffff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#eeeeee"
      }
    },
    {
      "scope": [
        "variable",
        "entity.name.variable",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#cccccc"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#555555",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "delimiter"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#dddddd",
        "fontStyle": "underline"
      }
    }
  ]
}
